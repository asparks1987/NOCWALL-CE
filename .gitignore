# Ignore PowerShell scripts and build scripts
*.ps1
# Any file/dir starting with 'build' (build scripts, helpers, build folders)
# Specific patterns for old names
build-*.sh
build-*.ps1

# Ignore build artifacts and caches
cache/
*.sqlite
*.log

# Ignore env and secrets
.env
*.env
.env.local
.env.*.local
.secrets/

# Android local config and credentials
android/local.properties
android/app/google-services.json
android/app/keystore
android/app/keystore.jks
android/app/full/release/*.aab

# Node / editor / OS
node_modules/
.vscode/
.DS_Store
Thumbs.db

vendor/
